# Second aggregate to widen the eval — confirms the recipe handles multiple
# aggregates with different shapes from the same project.

recipe: aggregate
af4: evals/fixtures/axon4/heroes/Calendar.java
af5: evals/fixtures/axon5/heroes/Calendar.java

require: @EventSourced(tagKey = "Calendar"
require: EventAppender eventAppender
require: @EntityCreator
require: @CommandHandler

forbid: @AggregateIdentifier
forbid: AggregateLifecycle
forbid: @CreationPolicy
